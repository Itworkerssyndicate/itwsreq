rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== قواعد عامة ====================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    function isReviewer() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role in ['super_admin', 'admin', 'reviewer']);
    }
    
    function isViewer() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.role in ['super_admin', 'admin', 'reviewer', 'viewer']);
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isValidRequest(data) {
      return data != null && 
        data.name is string && 
        data.nid is string && 
        data.phone is string &&
        data.nid.size() == 14 &&
        data.phone.size() >= 11;
    }
    
    // ==================== مجموعة الطلبات (Requests) ====================
    match /Requests/{requestId} {
      
      // قراءة الطلبات
      allow read: if isViewer();
      
      // إنشاء طلب جديد (متاح للجميع حتى بدون تسجيل)
      allow create: if request.auth == null || isValidRequest(request.resource.data);
      
      // تحديث طلب (للمراجعين فقط)
      allow update: if isReviewer() && 
        request.resource.data.status != resource.data.status &&
        request.resource.data.tracking.size() > resource.data.tracking.size();
      
      // حذف طلب (للمشرفين فقط)
      allow delete: if isAdmin();
      
      // التحقق من صحة البيانات عند الإنشاء
      allow create: if request.auth == null || (
        request.resource.data.name is string &&
        request.resource.data.name.size() > 5 &&
        request.resource.data.nid is string &&
        request.resource.data.nid.matches('^[0-9]{14}$') &&
        request.resource.data.phone is string &&
        request.resource.data.phone.matches('^01[0-9]{9}$') &&
        request.resource.data.type in ['شكوى', 'اقتراح'] &&
        request.resource.data.status in ['تم الاستلام', 'قيد المراجعة', 'جاري التنفيذ', 'تم الحل', 'تم الإغلاق النهائي', 'تمت القراءة', 'لم يقرأ']
      );
    }
    
    // ==================== مجموعة المستخدمين (Users) ====================
    match /Users/{userId} {
      
      // قراءة بيانات المستخدمين
      allow read: if isAuthenticated();
      
      // إنشاء مستخدم جديد (فقط الأدمن)
      allow create: if isAdmin() && 
        request.resource.data.username is string &&
        request.resource.data.role in ['super_admin', 'admin', 'reviewer', 'viewer', 'data_entry'];
      
      // تحديث بيانات المستخدم
      allow update: if (isAdmin() || isOwner(userId)) && 
        request.resource.data.role == resource.data.role; // منع تغيير الدور إلا للأدمن
      
      // حذف مستخدم (فقط الأدمن)
      allow delete: if isAdmin();
      
      // منع تعديل بعض الحقول الحساسة
      allow update: if (isAdmin() || isOwner(userId)) && (
        request.resource.data.password == resource.data.password || // منع تغيير الباسورد إلا بطريقة آمنة
        request.resource.data.permissions == resource.data.permissions // منع تغيير الصلاحيات إلا للأدمن
      );
    }
    
    // ==================== مجموعة سجل النظام (SystemLogs) ====================
    match /SystemLogs/{logId} {
      
      // قراءة السجلات (للمشرفين فقط)
      allow read: if isAdmin();
      
      // إنشاء سجل (للمستخدمين المصادق عليهم)
      allow create: if isAuthenticated() && 
        request.resource.data.action is string &&
        request.resource.data.userId == request.auth.uid;
      
      // منع التعديل أو الحذف للسجلات
      allow update, delete: if false;
    }
    
    // ==================== مجموعة الإعدادات (Settings) ====================
    match /Settings/{settingId} {
      
      // قراءة الإعدادات (للجميع)
      allow read: if true;
      
      // تعديل الإعدادات (للمشرفين فقط)
      allow write: if isAdmin();
    }
    
    // ==================== مجموعة الإحصائيات (Statistics) ====================
    match /Statistics/{statId} {
      
      // قراءة الإحصائيات (للمشاهدين)
      allow read: if isViewer();
      
      // تحديث الإحصائيات (للسيرفر فقط - عن طريق Functions)
      allow write: if false;
    }
    
    // ==================== مجموعة النسخ الاحتياطي (Backups) ====================
    match /Backups/{backupId} {
      
      // الوصول للنسخ الاحتياطية (للمشرفين فقط)
      allow read, write: if isAdmin();
    }
    
    // ==================== التحقق من صحة البيانات بشكل عام ====================
    match /{document=**} {
      // منع الحقول الضارة
      allow read, write: if request.resource.data.keys().hasAny(['__proto__', 'constructor', 'prototype']) == false;
      
      // الحد من حجم المستندات
      allow write: if request.resource.size() < 1024 * 1024; // 1MB كحد أقصى
    }
  }
}
