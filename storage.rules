rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // =====================================================================
    // دوال المساعدة
    // =====================================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && 
        firestore.get(/databases/(default)/documents/Users/$(request.auth.uid)).data.role == 'super_admin';
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (firestore.get(/databases/(default)/documents/Users/$(request.auth.uid)).data.role in 
          ['super_admin', 'admin']);
    }
    
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isPDF() {
      return request.resource.contentType == 'application/pdf';
    }
    
    // =====================================================================
    // قواعد مجلد الصور الشخصية
    // =====================================================================
    match /avatars/{userId}/{fileName} {
      
      // قراءة الصور الشخصية - للجميع
      allow read: if true;
      
      // رفع الصور الشخصية - للمستخدم نفسه أو الأدمن
      allow write: if isAuthenticated() && 
        (userId == request.auth.uid || isAdmin()) && 
        isImage() &&
        request.resource.size < 5 * 1024 * 1024; // 5MB كحد أقصى
      
      // حذف الصور الشخصية - للمستخدم نفسه أو الأدمن
      allow delete: if isAuthenticated() && 
        (userId == request.auth.uid || isAdmin());
    }
    
    // =====================================================================
    // قواعد مجلد مرفقات الطلبات
    // =====================================================================
    match /request-attachments/{requestId}/{fileName} {
      
      // قراءة المرفقات - للمستخدمين المصادق عليهم
      allow read: if isAuthenticated();
      
      // رفع المرفقات - لأي شخص يقدم طلب
      allow write: if (
        (isImage() || isPDF()) &&
        request.resource.size < 10 * 1024 * 1024 // 10MB كحد أقصى
      );
    }
    
    // =====================================================================
    // قواعد مجلد التقارير
    // =====================================================================
    match /reports/{reportId}/{fileName} {
      
      // قراءة التقارير - للمستخدمين المصادق عليهم
      allow read: if isAuthenticated();
      
      // إنشاء تقارير - للأدمن فقط
      allow write: if isAdmin() && isPDF();
    }
    
    // =====================================================================
    // قواعد مجلد النسخ الاحتياطية
    // =====================================================================
    match /backups/{backupId}/{fileName} {
      
      // الوصول للنسخ الاحتياطية - للسوبر أدمن فقط
      allow read, write: if isSuperAdmin();
    }
    
    // =====================================================================
    // قواعد عامة للأمان
    // =====================================================================
    match /{allPaths=**} {
      
      // منع أنواع الملفات الخطيرة
      allow write: if !request.resource.contentType.matches('application/x-executable|application/x-msdownload|text/html|application/javascript');
      
      // التحقق من حجم الملفات
      allow write: if request.resource.size < 50 * 1024 * 1024; // 50MB كحد أقصى عام
      
      // منع الوصول لأي مجلدات غير معرفة
      allow read, write: if false;
    }
  }
}
